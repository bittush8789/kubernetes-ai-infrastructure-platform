{
  "id": "ai-platform-realm",
  "realm": "ai-platform-realm",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator role with full control"
      },
      {
        "name": "ml-engineer",
        "description": "Can build, register, and deploy models in workspaces"
      },
      {
        "name": "viewer",
        "description": "Read-only access to workspaces, model registry, and metrics"
      }
    ]
  },
  "clients": [
    {
      "clientId": "platform-api",
      "enabled": true,
      "publicClient": false,
      "secret": "platform-api-secret-key-12345",
      "redirectUris": [
        "http://api.ai-platform.enterprise.internal/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "*"
      ]
    },
    {
      "clientId": "ai-portal",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://api.ai-platform.enterprise.internal/*"
      ],
      "webOrigins": [
        "*"
      ]
    }
  ]
}
