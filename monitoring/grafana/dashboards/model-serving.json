      },
      "id": 1,
      "title": "Total Inference Requests (QPS)",
      "type": "singlestat",
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "sum(rate(kserve_inference_request_duration_seconds_count[5m]))",
          "legendFormat": "QPS",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "Model Serving Success Rate",
      "type": "gauge",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(kserve_inference_request_duration_seconds_count{status=\"200\"}[5m])) / sum(rate(kserve_inference_request_duration_seconds_count[5m])) * 100",
          "legendFormat": "Success Rate %",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "title": "P99 Model Inference Latency (ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(kserve_inference_request_duration_seconds_bucket[5m])) by (le, inferenceservice)) * 1000",
          "legendFormat": "{{inferenceservice}} - P99",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 4,
      "title": "GPU Memory Allocation",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(container_memory_working_set_bytes{container=\"vllm-container\"}) by (pod) / 1024 / 1024 / 1024",
          "legendFormat": "{{pod}} (GB)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
